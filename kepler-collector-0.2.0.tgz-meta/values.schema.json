{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "config": {
            "type": "object",
            "properties": {
                "mcName": {
                    "type": "string"
                },
                "otlpEndpoint": {
                    "type": "string"
                },
                "otlpTenant": {
                    "type": "string"
                },
                "pollInterval": {
                    "type": "string"
                },
                "registryRepo": {
                    "type": "string"
                },
                "tektonNamespace": {
                    "type": "string"
                },
                "tektonWatermarkConfigMapName": {
                    "type": "string"
                },
                "watermarkConfigMapName": {
                    "type": "string"
                },
                "watermarkConfigMapNamespace": {
                    "type": "string"
                }
            }
        },
        "image": {
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "ociAuth": {
            "type": "object",
            "properties": {
                "existingSecret": {
                    "type": "string"
                },
                "passwordKey": {
                    "type": "string"
                },
                "usernameKey": {
                    "type": "string"
                }
            }
        },
        "resources": {
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "rules": {
            "type": "string"
        },
        "schedule": {
            "type": "string"
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "create": {
                    "type": "boolean"
                },
                "name": {
                    "type": "string"
                }
            }
        }
    }
}
