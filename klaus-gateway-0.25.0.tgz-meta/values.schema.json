{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string"
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "logLevel": {
      "type": "string",
      "enum": [
        "debug",
        "info",
        "warn",
        "error"
      ]
    },
    "server": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer"
        }
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "port": {
          "type": "integer"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        }
      }
    },
    "routing": {
      "type": "object",
      "properties": {
        "store": {
          "type": "string",
          "enum": [
            "memory",
            "bolt",
            "configmap"
          ]
        },
        "boltPath": {
          "type": "string"
        },
        "defaultTTL": {
          "type": "string"
        },
        "autoCreate": {
          "type": "boolean"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "klausctl",
            "operator",
            "static"
          ]
        },
        "klausctlBin": {
          "type": "string"
        },
        "operatorMCPURL": {
          "type": "string"
        },
        "operatorMCPToken": {
          "type": "string"
        },
        "staticInstances": {
          "type": "string"
        }
      }
    },
    "upstream": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "otlpEndpoint": {
          "type": "string"
        }
      }
    },
    "a2a": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultAgent": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "tokenPath": {
          "type": "string"
        },
        "fallbackIconUrlTemplate": {
          "type": "string",
          "description": "Fallback agent icon URL used when the AgentCard has no iconUrl. \"{agent}\" is replaced with the agentRef. Empty disables the fallback."
        },
        "saToken": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "audience": {
              "type": "string"
            },
            "mountPath": {
              "type": "string"
            },
            "expirationSeconds": {
              "type": "integer"
            }
          }
        }
      }
    },
    "agentgateway": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "gatewayClassName": {
          "type": "string"
        },
        "gateway": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean"
            },
            "parentRefs": {
              "type": "array"
            },
            "listeners": {
              "type": "array"
            },
            "annotations": {
              "type": "object"
            }
          }
        },
        "routes": {
          "type": "object",
          "properties": {
            "chatAndMcp": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "prefixes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "directInstance": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                }
              }
            },
            "cli": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "prefixes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "a2a": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "prefixes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "exactPaths": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "obo": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "prefixes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "policy": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "jwt": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "mode": {
                  "type": "string",
                  "enum": [
                    "Strict",
                    "Optional",
                    "Permissive"
                  ]
                },
                "issuer": {
                  "type": "string"
                },
                "audiences": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "jwks": {
                  "type": "object",
                  "properties": {
                    "mode": {
                      "type": "string",
                      "enum": [
                        "inline",
                        "remote"
                      ]
                    },
                    "inline": {
                      "type": "string"
                    },
                    "remote": {
                      "type": "object",
                      "properties": {
                        "jwksPath": {
                          "type": "string"
                        },
                        "cacheDuration": {
                          "type": "string"
                        },
                        "backendRef": {
                          "type": "object",
                          "properties": {
                            "group": {
                              "type": "string"
                            },
                            "kind": {
                              "type": "string"
                            },
                            "name": {
                              "type": "string"
                            },
                            "namespace": {
                              "type": "string"
                            },
                            "port": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "backendsExample": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            },
            "static": {
              "type": "object",
              "properties": {
                "host": {
                  "type": "string"
                },
                "port": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "slack": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "events",
            "socketmode"
          ]
        },
        "secretName": {
          "type": "string"
        },
        "dmMode": {
          "type": "string",
          "enum": [
            "",
            "serve",
            "redirect",
            "ignore"
          ]
        },
        "channelMode": {
          "type": "string",
          "enum": [
            "",
            "all",
            "allowlist",
            "none"
          ]
        },
        "channelAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dropStale": {
          "type": "boolean"
        },
        "progress": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "",
                "auto",
                "reactions",
                "text"
              ]
            },
            "emojis": {
              "type": "object",
              "properties": {
                "working": {
                  "type": "string"
                },
                "done": {
                  "type": "string"
                },
                "failed": {
                  "type": "string"
                }
              }
            },
            "clearReactionOnDone": {
              "type": [
                "boolean",
                "null"
              ]
            }
          }
        },
        "botToken": {
          "type": "string"
        },
        "signingSecret": {
          "type": "string"
        },
        "appToken": {
          "type": "string"
        }
      }
    },
    "obo": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "musterUrl": {
          "type": "string"
        },
        "callbackBaseUrl": {
          "type": "string"
        },
        "storePath": {
          "type": "string"
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "size": {
              "type": "string"
            },
            "accessMode": {
              "type": "string"
            },
            "storageClass": {
              "type": "string"
            },
            "existingClaim": {
              "type": "string"
            }
          }
        },
        "stateKey": {
          "type": "string"
        },
        "storeKey": {
          "type": "string"
        },
        "connectors": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the resource name for all Kubernetes objects. Useful when deploying as a subchart."
    },
    "web": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable the web channel adapter at /web/* on the public mux."
        }
      }
    },
    "cli": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable the CLI channel adapter at /cli/v1/*."
        }
      }
    }
  }
}
